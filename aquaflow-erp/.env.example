# Frontend Environment Variables
# Copy this file to .env and fill in the values

# ─── Development ───────────────────────────────────────────────────────────────
# Leave both empty in development — Vite proxies /api to localhost:5000
VITE_API_URL=
VITE_WS_URL=

# ─── Production (Vercel) ───────────────────────────────────────────────────────
# Set these in the Vercel dashboard under Project → Settings → Environment Variables
# VITE_API_URL=https://aquafeed-erp-api.onrender.com
# VITE_WS_URL=https://aquafeed-erp-api.onrender.com
