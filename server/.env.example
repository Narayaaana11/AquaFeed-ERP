# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB — local development
MONGODB_URI=mongodb://localhost:27017/aquafeed
# MongoDB Atlas (production — use this on Render):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aquafeed?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Origins (comma-separated)
# Development: leave as default (localhost)
# Production on Render: set to your Vercel frontend URL
# CORS_ORIGINS=https://aqua-feed-erp.vercel.app,https://your-custom-domain.com
